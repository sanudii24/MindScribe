{
  "name": "mindscribe-client",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude src/test/integration/** --exclude src/test/ui/**",
    "test:integration": "vitest run src/test/integration",
    "test:ui": "vitest run src/test/ui",
    "test:report": "node scripts/run-test-report.js",
    "build:tauri": "vite build && node scripts/slim-tauri-dist.js",
    "download:native-models": "node scripts/download-native-gguf-models.js",
    "preview": "vite preview",
    "eval:rag": "node scripts/evaluate-rag.js",
    "eval:rag:report": "node scripts/evaluate-rag.js --input scripts/rag-eval-sample.json --out scripts/rag-eval-report.json",
    "eval:rag:gate": "node scripts/evaluate-rag-gate.js --input scripts/rag-eval-sample.json --config scripts/rag-quality-gate.json --baseline phase1-baseline --candidate phase2-rerank",
    "eval:prompt:gate": "node scripts/evaluate-prompt-gate.js --config scripts/prompt-quality-gate.json",
    "download:voice-models": "node scripts/download-voice-models.js",
    "postinstall": "node scripts/fix-piper-wasm.js && node scripts/download-voice-models.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.85.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.12",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "localforage": "^1.10.0",
    "lucide-react": "^0.539.0",
    "path": "^0.12.7",
    "piper-wasm": "^0.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.4",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "wouter": "^3.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "happy-dom": "^20.8.9",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.2",
    "vite": "^6.4.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.1.2"
  }
}
